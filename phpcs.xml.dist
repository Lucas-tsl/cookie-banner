<?xml version="1.0"?>
<ruleset name="BanniereCookieCustom">
    <description>Règles de code pour le plugin Bannière Cookie Custom</description>

    <file>.</file>
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>

    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- Sécurité : échappement, sanitisation, nonces -->
    <rule ref="WordPress.Security"/>

    <!-- Internationalisation -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="banniere-cookie-custom"/>
            </property>
        </properties>
    </rule>

    <!-- Bonnes pratiques d'enregistrement des scripts/styles -->
    <rule ref="WordPress.WP.EnqueuedResources"/>

    <!-- Fonctions de debug oubliées -->
    <rule ref="WordPress.PHP.DevelopmentFunctions"/>

    <!-- Préfixe obligatoire pour toutes les fonctions/constantes/options globales -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="bcc"/>
            </property>
        </properties>
    </rule>
</ruleset>
